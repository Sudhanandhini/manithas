# MySQL connection string used by Prisma
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@localhost:3306/exomac"

# Public base URL of the site (no trailing slash) - used for sitemap.xml and canonical URLs
NEXT_PUBLIC_SITE_URL="https://www.example.com"

# NextAuth
# Generate a secret with: npx auth secret   (or: openssl rand -base64 32)
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3008"

# Seed-only: used once by `npx prisma db seed` to create the first admin login.
# Not read at runtime, safe to remove after the first seed.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-now"

# SMTP - used to email customers/admin about support ticket activity.
# Leave unset to disable email sending (tickets still work, emails are skipped).
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="postmaster@example.com"
SMTP_PASSWORD="replace-with-real-smtp-password"
SMTP_FROM="support@example.com"

# Admin notification address for new ticket / customer reply emails.
# Reuses the seed-only ADMIN_EMAIL above if you don't set a separate one.
TICKET_NOTIFY_EMAIL="admin@example.com"
