generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// One row per site route. `slug` is the site-relative path, e.g. "/", "/about".
model SeoPage {
  id             String   @id @default(cuid())
  slug           String   @unique
  label          String
  title          String?
  description    String?  @db.Text
  keywords       String?
  ogTitle        String?
  ogDescription  String?  @db.Text
  ogImage        String?
  canonicalUrl   String?
  noindex        Boolean  @default(false)
  nofollow       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// A managed list of blog category names the admin can pick from when writing a
// post. `BlogPost.categories` still stores the assigned names as a comma-separated
// string, so this table only drives the picker UI - it isn't a foreign key.
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
}

// A blog post, authored in the admin panel and rendered on /blog-grid and
// /blog-details/[slug]. `slug` is the SEO-friendly URL segment.
model BlogPost {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  excerpt         String?  @db.Text
  content         String   @db.Text
  image           String?
  largeImage      String?
  author          String   @default("Admin")
  categories      String?
  tags            String?
  metaTitle       String?
  metaDescription String?  @db.Text
  noindex         Boolean  @default(false)
  published       Boolean  @default(true)
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// A solution/service offering, authored in the admin panel and rendered on
// /solution and /solution-details/[slug]. `slug` is the SEO-friendly URL segment.
model Solution {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  excerpt           String?  @db.Text
  content           String   @db.Text
  image             String?
  largeImage        String?
  client            String?
  categories        String?
  awards            String?
  ctaText           String?
  ctaLink           String?
  subContentTitle   String?
  subContentText    String?  @db.Text
  galleryImageOne   String?
  galleryImageTwo   String?
  galleryImageThree String?
  metaTitle         String?
  metaDescription   String?  @db.Text
  noindex           Boolean  @default(false)
  published         Boolean  @default(true)
  publishedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// A customer account, created by an admin, used to log in separately from
// the admin panel to raise and track support tickets.
model Customer {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  email        String?
  mobile       String?
  website      String?
  domain       String?
  address      String?  @db.Text
  companyName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tickets      Ticket[]
}

// A support ticket raised by a customer.
model Ticket {
  id             String          @id @default(cuid())
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  subject        String
  category       String
  status         String          @default("New")
  priority       String          @default("Medium")
  link           String?
  lastActivityAt DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  messages       TicketMessage[]

  @@index([customerId])
}

// One message in a ticket's thread - the first message is the customer's
// original report, followed by replies from either side.
model TicketMessage {
  id               String             @id @default(cuid())
  ticketId         String
  ticket           Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType       String
  senderName       String
  message          String             @db.Text
  isReadByCustomer Boolean            @default(false)
  isReadByAdmin    Boolean            @default(false)
  createdAt        DateTime           @default(now())
  attachments      TicketAttachment[]

  @@index([ticketId])
}

// A file attached to a ticket message.
model TicketAttachment {
  id        String        @id @default(cuid())
  messageId String
  message   TicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime      @default(now())

  @@index([messageId])
}

// Singleton row (id = 1) holding site-wide SEO defaults.
model SiteSettings {
  id                     Int      @id @default(1)
  siteName               String   @default("Exomac")
  titleTemplate          String   @default("%s | Exomac")
  defaultDescription     String?  @db.Text
  defaultOgImage         String?
  robotsTxt              String   @db.Text
  googleSiteVerification String?
  bingSiteVerification   String?
  updatedAt              DateTime @updatedAt
}
